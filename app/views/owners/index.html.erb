<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Owners</h1>
  <%= link_to "New Owner", new_owner_path, class: "btn btn-success" %>
</div>

<table class="table table-striped table-hover mt-3">
  <thead class="table-dark">
    <tr>
      <th>Full Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Number of Pets</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% @owners.each do |owner| %>
      <tr>
        <td><%= owner.first_name %> <%= owner.last_name %></td>
        <td><%= owner.email %></td>
        <td><%= owner.phone %></td>
        <td><%= owner.pets.count %></td>
        <td>
          <div class="d-flex gap-2">
            <%= link_to "View Details", owner_path(owner), class: "btn btn-sm btn-primary" %>
            <!-- Botón Edit -->
            <%= link_to "Edit", edit_owner_path(owner), class: "btn btn-sm btn-warning" %>
            <!-- Botón Delete con confirmación -->
            <%= button_to "Delete", owner_path(owner), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>