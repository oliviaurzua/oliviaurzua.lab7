<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Appointments</h1>
  <%= link_to "New Appointment", new_appointment_path, class: "btn btn-success" %>
</div>

<table class="table table-striped table-hover mt-3">
  <thead class="table-dark">
    <tr>
      <th>Date</th>
      <th>Pet Name</th>
      <th>Vet Name</th>
      <th>Reason</th>
      <th>Status</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% @appointments.each do |app| %>
      <tr>
        <td><%= app.date.strftime("%B %d, %Y") %></td>
        <td><%= link_to app.pet.name, pet_path(app.pet) %></td>
        <td><%= link_to "#{app.vet.first_name} #{app.vet.last_name}", vet_path(app.vet) %></td>
        <td><%= app.reason %></td>
        <td><span class="badge bg-secondary"><%= app.status.titleize %></span></td>
        <td>
          <div class="d-flex gap-2">
            <%= link_to "View Details", appointment_path(app), class: "btn btn-sm btn-primary" %>
            <%= link_to "Edit", edit_appointment_path(app), class: "btn btn-sm btn-warning" %>
            <%= button_to "Delete", appointment_path(app), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>