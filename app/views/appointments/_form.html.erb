<%= form_with(model: appointment) do |form| %>
<%= render "shared/error_messages", object: appointment %>
  <div class="mb-3">
    <%= form.label :date, "Appointment Date & Time", class: "form-label" %>
    <%= form.datetime_field :date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :reason, "Reason for Visit", class: "form-label" %>
    <%= form.text_area :reason, rows: 3, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :status, "Status", class: "form-label" %>
    <%= form.select :status, Appointment.statuses.keys.map { |s| [s.titleize, s] }, { prompt: "Select status..." }, { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= form.label :pet_id, "Pet", class: "form-label" %>
    <%= form.collection_select :pet_id, Pet.all, :id, :name, { prompt: "Select a pet..." }, { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= form.label :vet_id, "Veterinarian", class: "form-label" %>
    <%= form.collection_select :vet_id, Vet.all, :id, :email, { prompt: "Select a vet..." }, { class: "form-select" } %>
  </div>

  <div>
    <%= form.submit "Save Appointment", class: "btn btn-primary" %>
  </div>
<% end %>