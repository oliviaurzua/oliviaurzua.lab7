<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Pets</h1>
  <%= link_to "New Pet", new_pet_path, class: "btn btn-success" %>
</div>

<table class="table table-striped table-hover mt-3">
  <thead class="table-dark">
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
      <th>Owner Name</th>
      <th>Date of Birth</th>
      <th>Action</th>
      <th>Photo</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= pet.name %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= link_to "#{pet.owner.first_name} #{pet.owner.last_name}", owner_path(pet.owner) %></td>
        <td><%= pet.date_of_birth&.strftime("%B %d, %Y") %></td>
        <td>
          <div class="d-flex gap-2">
            <%= link_to "View Details", pet_path(pet), class: "btn btn-sm btn-primary" %>
            <%= link_to "Edit", edit_pet_path(pet), class: "btn btn-sm btn-warning" %>
            <%= button_to "Delete", pet_path(pet), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
          </div>
        </td>
        <td>
          <% if pet.photo.attached? %>
            <%= image_tag pet.photo.variant(resize_to_fill: [60, 60]), class: "rounded" %>
          <% else %>
            <div class="bg-light rounded d-inline-block" style="width: 60px; height: 60px;"></div>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>