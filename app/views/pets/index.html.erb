<h1>Pets</h1>
<table class="table table-striped table-hover mt-3">
  <thead class="table-dark">
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
      <th>Owner Name</th>
      <th>Date of Birth</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= pet.name %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= link_to "#{pet.owner.first_name} #{pet.owner.last_name}", owner_path(pet.owner) %></td>
        <td><%= pet.date_of_birth&.strftime("%B %d, %Y") %></td>
        <td><%= link_to "View Details", pet_path(pet), class: "btn btn-sm btn-primary" %></td>
      </tr>
    <% end %>
  </tbody>
</table>