<%= form_with(model: pet) do |form| %>
<%= render "shared/error_messages", object: pet %>
  <div class="mb-3">
    <%= form.label :name, "Name", class: "form-label" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :species, "Species", class: "form-label" %>
    <%= form.text_field :species, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :breed, "Breed", class: "form-label" %>
    <%= form.text_field :breed, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :weight, "Weight (kg)", class: "form-label" %>
    <%= form.number_field :weight, step: "0.1", class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :date_of_birth, "Date of Birth", class: "form-label" %>
    <%= form.date_field :date_of_birth, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :owner_id, "Owner", class: "form-label" %>
    <%= form.collection_select :owner_id, Owner.all, :id, :email, { prompt: "Select an owner..." }, { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= form.label :photo, class: "form-label" %>
  
    <% if form.object.photo.attached? %>
      <div class="mb-2">
        <span class="d-block text-muted" style="font-size: 0.9em;">Current photo:</span>
        <%= image_tag form.object.photo, style: "width: 100px;", class: "rounded" %>
      </div>
    <% end %>

    <%= form.file_field :photo, class: "form-control" %>
  </div>

  <div>
    <%= form.submit "Save Pet", class: "btn btn-primary" %>
  </div>
<% end %>