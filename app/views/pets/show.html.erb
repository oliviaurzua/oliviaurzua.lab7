<div class="card mb-4">
  <div class="card-header bg-success text-white">
    <h2><%= @pet.name %></h2>
  </div>
  <div class="card-body">
    <p><strong>Species:</strong> <%= @pet.species %></p>
    <p><strong>Breed:</strong> <%= @pet.breed %></p>
    <p><strong>Date of Birth:</strong> <%= @pet.date_of_birth&.strftime("%B %d, %Y") %></p>
    <p><strong>Weight:</strong> <%= @pet.weight %> kg</p>
    <p><strong>Owner:</strong> <%= link_to "#{@pet.owner.first_name} #{@pet.owner.last_name}", owner_path(@pet.owner) %></p>
  </div>
</div>

<div class="mb-4">
  <% if @pet.photo.attached? %>
    <%= image_tag @pet.photo, class: "img-fluid rounded", style: "max-width: 300px;" %>
  <% else %>
    <div class="p-3 bg-light text-secondary rounded d-inline-block" style="width: 300px; text-align: center;">
      <i class="bi bi-camera"></i> No photo available
    </div>
  <% end %>
</div>

<h3>Appointments</h3>
<ul class="list-group">
  <% @pet.appointments.upcoming.each do |app| %>
    <li class="list-group-item">
      <%= link_to app.date.strftime("%B %d, %Y - %H:%M"), appointment_path(app) %> | Reason: <%= app.reason %>
    </li>
  <% end %>
</ul>

<div class="d-flex gap-2 mt-4">
  <%= link_to "Back to Pets", pets_path, class: "btn btn-secondary" %>
  <%= link_to "Edit", edit_pet_path(@pet), class: "btn btn-warning" %>
  <%= button_to "Delete", pet_path(@pet), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
</div>