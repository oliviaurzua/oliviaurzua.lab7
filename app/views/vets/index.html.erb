<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Veterinarians</h1>
  <%= link_to "New Veterinarian", new_vet_path, class: "btn btn-success" %>
</div>

<table class="table table-striped table-hover mt-3">
  <thead class="table-dark">
    <tr>
      <th>Full Name</th>
      <th>Email</th>
      <th>Specialization</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% @vets.each do |vet| %>
      <tr>
        <td><%= vet.first_name %> <%= vet.last_name %></td>
        <td><%= vet.email %></td>
        <td><%= vet.specialization %></td>
        <td>
          <div class="d-flex gap-2">
            <%= link_to "View Details", vet_path(vet), class: "btn btn-sm btn-primary" %>
            <%= link_to "Edit", edit_vet_path(vet), class: "btn btn-sm btn-warning" %>
            <%= button_to "Delete", vet_path(vet), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>