<%= form_with(model: vet) do |form| %>
<%= render "shared/error_messages", object: vet %>
  <div class="mb-3">
    <%= form.label :first_name, "First Name", class: "form-label" %>
    <%= form.text_field :first_name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :last_name, "Last Name", class: "form-label" %>
    <%= form.text_field :last_name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :specialization, "Specialization", class: "form-label" %>
    <%= form.text_field :specialization, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :email, "Email", class: "form-label" %>
    <%= form.text_field :email, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :phone, "Phone", class: "form-label" %>
    <%= form.text_field :phone, class: "form-control" %>
  </div>

  <div>
    <%= form.submit "Save Vet", class: "btn btn-primary" %>
  </div>
<% end %>